# =============================================================================
# Vision-OS — .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
out/
.cache/

# Environment / secrets — NEVER commit these
.env
.env.local
.env.*.local
.env.development
.env.production

# Editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/
*.lcov
.vitest-cache/

# TypeScript build cache
*.tsbuildinfo
.tsc-cache/

# Vite
.vite/

# Firebase / Google Cloud
firebase-debug.log
firestore-debug.log
.firebase/
service-account*.json
*-service-account.json
*-firebase-adminsdk-*.json

# Misc
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
.turbo/
*.local

# Devin / agent local config (kept locally only, not shared)
.devin/config.local.json
