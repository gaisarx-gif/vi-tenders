# =============================================================================
# Vision-OS — Environment Variables (Example)
# =============================================================================
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local — it contains secrets.
#
# Step-by-step instructions for each value: see SETUP.md
# =============================================================================


# -----------------------------------------------------------------------------
# Server runtime
# -----------------------------------------------------------------------------

# Set to "production" only when deploying. Leave unset (or "development") locally.
NODE_ENV=development

# Comma-separated allowed CORS origins (production).
# In development, http://localhost:3000 is allowed by default.
ALLOWED_ORIGIN=http://localhost:3000


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Random secret used to sign JWT cookies. MUST be set in production.
# Generate one with (Git Bash on Windows, or any *nix):
#     openssl rand -base64 48
# Or in Node:
#     node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace_me_with_a_long_random_string

# Email of the application owner / super-admin (must be a Google account).
# This account always has admin role even if it isn't in authorized_employees.
OWNER_EMAIL=aawad39506@gmail.com


# -----------------------------------------------------------------------------
# AI Provider — Google Gemini
# -----------------------------------------------------------------------------

# Default provider. Currently only "gemini" is implemented.
AI_PROVIDER=gemini

# Get your free Gemini API key from:
#     https://aistudio.google.com/apikey
# (See SETUP.md for full step-by-step.)
# Free tier: 15 requests/min, 1500 req/day, 1M tokens/day.
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# Optional: Gemini model name. Defaults to "gemini-2.5-flash" (stable free-tier model).
# Override only if you have a paid plan or want to test a preview model
# (e.g. "gemini-3-flash-preview"). See https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# Firebase — server (Admin SDK)
# -----------------------------------------------------------------------------
# Find these at:
#   https://console.firebase.google.com → your project →
#   ⚙ Project settings → "General" tab → "Your apps" → Web app → SDK setup → Config

FIREBASE_PROJECT_ID=gen-lang-client-0455111868
FIREBASE_DATABASE_ID=ai-studio-8f0bb76a-1dd5-4bc2-8b03-ebcbc19d198e

# The auth domain Firebase Auth redirects to. We proxy /__/auth through our
# server, so the client side uses window.location.host instead — but the
# server still needs this for the proxy target.
FIREBASE_AUTH_DOMAIN=gen-lang-client-0455111868.firebaseapp.com

# For production deployment: the full JSON content of the Firebase service
# account key. Copy the contents of your service-account*.json file here.
# In local dev this is not needed — GOOGLE_APPLICATION_CREDENTIALS is used instead.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}


# -----------------------------------------------------------------------------
# Firebase — client (exposed to browser via Vite's import.meta.env)
# -----------------------------------------------------------------------------
# Same Firebase config, but VITE_-prefixed so Vite includes them in the bundle.
# These values are PUBLIC by design (Firebase web API keys are not secrets);
# real protection comes from Firestore security rules + App Check.
# https://firebase.google.com/docs/projects/api-keys

VITE_FIREBASE_API_KEY=AIzaSy_your_firebase_web_api_key_here
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0455111868
VITE_FIREBASE_APP_ID=1:257748426713:web:f586f7e82253c13bbd83c8
VITE_FIREBASE_MESSAGING_SENDER_ID=257748426713
VITE_FIREBASE_AUTH_DOMAIN=gen-lang-client-0455111868.firebaseapp.com
VITE_FIREBASE_DATABASE_ID=ai-studio-8f0bb76a-1dd5-4bc2-8b03-ebcbc19d198e
VITE_FIREBASE_STORAGE_BUCKET=gen-lang-client-0455111868.firebasestorage.app
VITE_FIREBASE_MEASUREMENT_ID=


# -----------------------------------------------------------------------------
# Vite dev server
# -----------------------------------------------------------------------------

# Set DISABLE_HMR=true when running inside an AI Studio sandbox that flickers
# during agent edits. Leave unset for normal local dev.
# DISABLE_HMR=true
